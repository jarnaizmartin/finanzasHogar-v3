# Web3Forms — Email delivery for license requests & recovery codes
# Get your access key at https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Google Drive sync (opt-in, multi-device vault) — OAuth Client ID
# Create at https://console.cloud.google.com → APIs & Services → Credentials
#   · OAuth client type: Web application
#   · Scope: https://www.googleapis.com/auth/drive.appdata
#   · Authorized JS origins: https://finanzas-hogar-eta.vercel.app + http://localhost:5173
#   · Authorized redirect URIs (ADR §11): <prod>/oauth-callback + http://localhost:5173/oauth-callback
# Public by design (the client_id is not a secret).
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ─── ADR §11 — Reconexión automática (Authorization Code + PKCE) ─────────────
# Server-side ONLY. Used by the stateless auth function api/google-token.ts to
# exchange the auth code for a refresh_token and refresh access tokens silently.
# NEVER expose these to the client (no VITE_ prefix → not bundled).
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
# Optional: comma-separated allowed origins for the auth function (CORS).
# Defaults to https://finanzas-hogar-eta.vercel.app + http://localhost:5173
# OAUTH_ALLOWED_ORIGINS=https://finanzas-hogar-eta.vercel.app,http://localhost:5173
